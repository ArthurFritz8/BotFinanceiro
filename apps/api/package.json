{
  "name": "@botfinanceiro/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/server.js",
  "scripts": {
    "build": "tsc -b",
    "db:migrate": "tsx src/shared/persistence/run-migrations-cli.ts",
    "dev": "tsx watch src/main/server.ts",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "start": "node dist/main/server.js",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.1.0",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "ws": "^8.20.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2"
  }
}
