# URL base da API para build/deploy publico do frontend.
# Exemplo: https://sua-api.onrender.com
# Em GitHub Pages, configure esta chave em Settings > Secrets and variables > Actions > Variables.
VITE_API_BASE_URL=

# Base path para hosting estatico com subdiretorio (ex.: /BotFinanceiro/ no GitHub Pages).
# Para dominio raiz, deixe vazio ou use /
VITE_BASE_PATH=

# Supabase (obrigatorio para login e historico por usuario)
# Em GitHub Pages, configure ambas em Settings > Secrets and variables > Actions > Variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Token interno opcional para paineis de auditoria/health no Chart Lab.
# Use apenas em ambientes internos e com o mesmo valor de INTERNAL_API_TOKEN na API.
# Alternativa runtime: window.__botfinanceiroSetInternalToken('seu_token').
VITE_INTERNAL_API_TOKEN=
