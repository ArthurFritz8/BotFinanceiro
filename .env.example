# App
NODE_ENV=development
APP_PORT=3000

# Logging
LOG_LEVEL=info

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_ECONOMY_MODE=false
SCHEDULER_JITTER_MAX_PERCENT=20

# Sync policy (crypto)
CRYPTO_SYNC_TARGET_CURRENCY=usd
CRYPTO_SYNC_HOT_ASSETS=bitcoin,ethereum,solana
CRYPTO_SYNC_WARM_ASSETS=chainlink,avalanche-2,polygon
CRYPTO_SYNC_COLD_ASSETS=aave,maker,uniswap

# Cache
CACHE_DEFAULT_TTL_SECONDS=120
CACHE_STALE_SECONDS=300

# Providers (exemplos)
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_TIMEOUT_MS=5000
COINGECKO_DAILY_BUDGET=1000
COINGECKO_MAX_REQUESTS_PER_MINUTE=10
COINGECKO_RETRY_ATTEMPTS=3
COINGECKO_RETRY_BASE_DELAY_MS=250
COINGECKO_RETRY_JITTER_PERCENT=25
COINGECKO_CIRCUIT_FAILURE_THRESHOLD=5
COINGECKO_CIRCUIT_COOLDOWN_MS=60000
COINGECKO_CIRCUIT_ALERT_OPEN_CYCLES=3
COINGECKO_CIRCUIT_ALERT_COOLDOWN_MS=300000
OPS_HEALTH_WARNING_BUDGET_PERCENT=20
OPS_HEALTH_CRITICAL_BUDGET_PERCENT=5
OPS_HEALTH_WARNING_SCOPE_FAILURE_RATE_PERCENT=50
OPS_HEALTH_CRITICAL_SCOPE_FAILURE_RATE_PERCENT=80
OPS_HEALTH_SNAPSHOT_ENABLED=true
OPS_HEALTH_SNAPSHOT_INTERVAL_SECONDS=60
OPS_HEALTH_SNAPSHOT_MAX_ITEMS=300
OPS_HEALTH_SNAPSHOT_FILE_PATH=.runtime/operational-health-history.json
YAHOO_FINANCE_API_BASE_URL=https://query1.finance.yahoo.com

# Database (se aplicavel)
DATABASE_URL=

# Security
JWT_SECRET=

# Internal routes security
INTERNAL_API_TOKEN=
INTERNAL_ALLOWED_IPS=
