# App
NODE_ENV=development
APP_PORT=3000

# Logging
LOG_LEVEL=info

# CORS (origens permitidas para frontend publico, separadas por virgula)
CORS_ALLOWED_ORIGINS=

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_ECONOMY_MODE=false
SCHEDULER_JITTER_MAX_PERCENT=20

# Sync policy (crypto)
CRYPTO_SYNC_TARGET_CURRENCY=usd
CRYPTO_SYNC_HOT_ASSETS=bitcoin,ethereum,solana
CRYPTO_SYNC_WARM_ASSETS=chainlink,avalanche-2,polygon
CRYPTO_SYNC_COLD_ASSETS=aave,maker,uniswap

# Cache
CACHE_DEFAULT_TTL_SECONDS=120
CACHE_STALE_SECONDS=300
MARKET_OVERVIEW_CACHE_TTL_SECONDS=60

# Providers (exemplos)
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_TIMEOUT_MS=5000
COINGECKO_DAILY_BUDGET=1000
COINGECKO_MAX_REQUESTS_PER_MINUTE=10
COINGECKO_RETRY_ATTEMPTS=3
COINGECKO_RETRY_BASE_DELAY_MS=250
COINGECKO_RETRY_JITTER_PERCENT=25
COINGECKO_CIRCUIT_FAILURE_THRESHOLD=5
COINGECKO_CIRCUIT_COOLDOWN_MS=60000
COINGECKO_CIRCUIT_ALERT_OPEN_CYCLES=3
COINGECKO_CIRCUIT_ALERT_COOLDOWN_MS=300000
COINCAP_API_BASE_URL=https://api.coincap.io/v2
COINCAP_TIMEOUT_MS=5000
OPS_HEALTH_WARNING_BUDGET_PERCENT=20
OPS_HEALTH_CRITICAL_BUDGET_PERCENT=5
OPS_HEALTH_WARNING_SCOPE_FAILURE_RATE_PERCENT=50
OPS_HEALTH_CRITICAL_SCOPE_FAILURE_RATE_PERCENT=80
OPS_HEALTH_SNAPSHOT_ENABLED=true
OPS_HEALTH_SNAPSHOT_INTERVAL_SECONDS=60
OPS_HEALTH_SNAPSHOT_MAX_ITEMS=300
OPS_HEALTH_SNAPSHOT_RETENTION_DAYS=30
OPS_HEALTH_SNAPSHOT_FILE_PATH=.runtime/operational-health-history.json
YAHOO_FINANCE_API_BASE_URL=https://query1.finance.yahoo.com
YAHOO_FINANCE_TIMEOUT_MS=5000
BINANCE_API_BASE_URL=https://api.binance.com
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443
BINANCE_TIMEOUT_MS=5000
BINANCE_FUTURES_API_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_WS_ENABLED=true
BINANCE_FUTURES_WS_BASE_URL=wss://fstream.binance.com
BINANCE_FUTURES_TIMEOUT_MS=5000
AIRDROPS_TIMEOUT_MS=6000
AIRDROPS_MAX_ITEMS_PER_SOURCE=30
AIRDROPS_IO_SOURCE_URL=https://airdrops.io
AIRDROP_ALERT_SOURCE_URL=https://airdropalert.com
DEFILLAMA_API_BASE_URL=https://api.llama.fi
AIRDROPS_DROPS_TAB_SOURCE_URL=
AIRDROPS_DROPS_TAB_API_KEY=
AIRDROPS_EARNIFI_SOURCE_URL=
AIRDROPS_EARNIFI_API_KEY=
MEME_RADAR_TIMEOUT_MS=7000
MEME_RADAR_REFRESH_INTERVAL_SECONDS=300
MEME_RADAR_NEW_POOLS_PER_CHAIN=8
MEME_RADAR_DEX_ENRICH_LIMIT=8
MEME_RADAR_AI_MAX_ITEMS=6
MEME_RADAR_CACHE_FRESH_SECONDS=120
MEME_RADAR_CACHE_STALE_SECONDS=300
MEME_RADAR_CONSENSUS_WEIGHT_BUNDLE_RISK=35
MEME_RADAR_CONSENSUS_WEIGHT_SECURITY_STATUS=25
MEME_RADAR_CONSENSUS_WEIGHT_LIQUIDITY_DEPTH=20
MEME_RADAR_CONSENSUS_WEIGHT_WEB_SIGNAL=10
MEME_RADAR_CONSENSUS_WEIGHT_COMMUNITY_HEALTH=10
# Calendario macro institucional (opcional)
# Se vazio, o motor institucional usa agenda sintetica resiliente.
FOREX_MACRO_CALENDAR_URL=
FOREX_MACRO_CALENDAR_API_KEY=
IQOPTION_ENABLED=false
IQOPTION_API_BASE_URL=
IQOPTION_TIMEOUT_MS=5000

# Security
JWT_SECRET=

# Internal routes security
INTERNAL_API_TOKEN=
INTERNAL_ALLOWED_IPS=
# Em producao, use token aleatorio com no minimo 16 caracteres.

# OpenRouter (Copiloto IA)
# Nunca versionar chave real neste arquivo.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=15000
OPENROUTER_APP_NAME=BotFinanceiro
OPENROUTER_APP_URL=

# Web search providers (Copiloto IA)
# Estrategias:
# - tavily_only
# - tavily_then_serper
# - tavily_then_serper_then_serpapi
WEB_SEARCH_PROVIDER_STRATEGY=tavily_then_serper
WEB_SEARCH_DEXSCREENER_API_BASE_URL=https://api.dexscreener.com
WEB_SEARCH_SERPER_API_BASE_URL=https://google.serper.dev
WEB_SEARCH_SERPER_API_KEY=
WEB_SEARCH_SERPAPI_API_BASE_URL=https://serpapi.com
WEB_SEARCH_SERPAPI_API_KEY=
WEB_SEARCH_TAVILY_API_BASE_URL=https://api.tavily.com
# Deixe vazio para desabilitar Tavily
WEB_SEARCH_TAVILY_API_KEY=

# On-chain holders fallback (opcional)
# Usado quando DexScreener nao entrega distribuicao estruturada de holders.
ONCHAIN_BIRDSEYE_API_BASE_URL=https://public-api.birdeye.so/defi
ONCHAIN_BIRDSEYE_API_KEY=
ONCHAIN_BIRDSEYE_TIMEOUT_MS=7000

# Copilot audit trail
COPILOT_CHAT_AUDIT_ENABLED=true
COPILOT_CHAT_AUDIT_MAX_ITEMS=5000
COPILOT_CHAT_AUDIT_RETENTION_DAYS=90
COPILOT_CHAT_AUDIT_FILE_PATH=.runtime/copilot-chat-audit.json

# Database persistence (Supabase/Postgres)
DATABASE_PROVIDER=auto
DATABASE_AUTO_MIGRATE=true
DATABASE_URL=
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Frontend auth/session (Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=